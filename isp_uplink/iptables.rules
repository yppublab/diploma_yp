*nat
:PREROUTING ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]

# DNAT внешний->fw: весь трафик, пришедший на IP прокси на uplink
-A PREROUTING ! -s 172.56.200.100 -j DNAT --to-destination 172.56.200.100

# маскируем пакеты, которые пришли с самого докер-хоста (для остальных не требуется)
-A POSTROUTING -s 172.56.200.1 -j SNAT --to-source 172.56.200.254

COMMIT

*filter
:INPUT ACCEPT [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]

# Block outbound traffic to port 10128 (TCP/UDP)
-A OUTPUT -p tcp --dport 10128 -j DROP
-A OUTPUT -p udp --dport 10128 -j DROP
-A FORWARD -p tcp --dport 10128 -j DROP
-A FORWARD -p udp --dport 10128 -j DROP

COMMIT
